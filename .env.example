# OpenAI
OPENAI_API_KEY=

# Application
BACKEND_PUBLIC_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://hireiq:hireiq_secret@localhost:5432/hireiq
POSTGRES_USER=hireiq
POSTGRES_PASSWORD=hireiq_secret
POSTGRES_DB=hireiq
PGVECTOR_ENABLED=true

# Authentication
JWT_SECRET_KEY=change-me-to-a-random-64-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Calendar (OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_CALENDAR_ID=primary

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@hireiq.dev

# Cloud Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hireiq-resumes
R2_ENDPOINT_URL=
R2_REGION=auto

# ATS Webhooks
ATS_WEBHOOK_SECRET=
ATS_WEBHOOK_PROVIDER=greenhouse

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
